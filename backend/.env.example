# Sasyam Backend — Environment Variables
# Copy this to .env and fill in your values

# Hugging Face Hub (for model download)
HF_MODEL_REPO=your-hf-username/sasyam-crop-model
HF_TOKEN=

# Server
PORT=8000

# Optional: path to local H5 model file (skips HF download)
LOCAL_MODEL_PATH=sasyam_crop_model.h5

# Optional: folder containing sample images for /live-feed
SAMPLES_DIR=./sample_images
